

$content = Get-Content "C:\Users\xxx\Desktop\ps scripts\Tests.txt" -Raw -Encoding UTF8

$tests = $content -split "(?m)^;\s*-+\s*Test\s*#?\s*\d+\s*-+"

#Write-Host "Number of tests: $($tests.Count)"

function Parse-TextBlock($block) {
	
	$obj = [ordered]@{
		Title 			= ""
		Method 			= ""
		Disabled 		= ""
		Alerts 			= ""
		Comment			= ""
		SQLQuery		= ""
		#FullBlock		= $block.Trim()
		
	}

$inSpecific = $false

foreach ($line in $block -split "`n") {
	if ($line -match "^Title\s*=\s*(.+)") {
		$obj.Title = $Matches[1].Trim()
		continue
	}
	
	if ($line -match "^Method\s*=\s*(.+)") {
		$obj.Method = $Matches[1].Trim()
		continue
	}
	
	if ($line -match "^Disabled\s*=\s*(.+)") {
		$obj.Disabled = $Matches[1].Trim()
		continue
	}
	
	if ($line -match "^Alerts\s*=\s*(.+)") {
		$obj.Alerts = $Matches[1].Trim()
		continue
	}
	
	if ($line -match "^Comment\s*=\s*(.+)") {
		$obj.Comment = $Matches[1].Trim()
		continue
	}
	
	if ($line -match "^SQLQuery\s*=\s*(.+)") {
		$obj.SQLQuery = $Matches[1].Trim()
		continue
	}
	if ($line -match "^-+ Test specific properties -+") {
		$inSpecific = $true
		continue
	}
	
}

	return [PSCustomObject]$obj
}

$parsedTests = $tests | Where-Object { $_.Trim() -ne "" } | ForEach-Object { Parse-TextBlock $_ }
